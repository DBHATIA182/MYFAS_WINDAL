{
  "name": "windal-apptest",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5175 --strictPort",
    "dev:all": "concurrently -n api,web -c blue,green \"node server.cjs\" \"npm run dev\"",
    "build": "vite build",
    "build:tunnel": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5174 --strictPort",
    "preview:tunnel": "set WINDAL_TUNNEL_DEV=1&& vite preview --host 0.0.0.0 --port 5174 --strictPort",
    "tunnel:web": "npm run build && npm run preview:tunnel",
    "server": "node server.cjs",
    "start": "node server.cjs",
    "setup:client": "powershell -ExecutionPolicy Bypass -File .\\setup-client.ps1"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "html2pdf.js": "^0.14.0",
    "oracledb": "^6.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.2",
    "vite": "^5.0.10"
  }
}
